{
  "name": "medcare-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "pm2:start": "npm run build && pm2 start ecosystem.config.cjs --update-env",
    "pm2:restart": "npm run build && pm2 restart medcare-web --update-env",
    "pm2:reload:prod": "npm run build && pm2 delete medcare-web || true && pm2 start ecosystem.config.cjs --update-env",
    "pm2:stop": "pm2 stop medcare-web",
    "pm2:delete": "pm2 delete medcare-web",
    "pm2:logs": "pm2 logs medcare-web --lines 100"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "axios": "^1.18.1",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.7.0",
    "react-redux": "^9.3.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
